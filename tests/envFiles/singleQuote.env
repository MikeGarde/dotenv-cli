BASE=Hello

# Double quotes expand ${VAR}
EXPAND_DOUBLE="${BASE} World"

# Single quotes are literal — no expansion
LITERAL_SINGLE='${BASE} World'

# A password containing $ stays verbatim inside single quotes,
# even when it looks like a variable reference.
PASSWORD='p${BASE}ss$w0rd$'

# Bare $ (no braces) is never expanded, in any quoting style
BARE_DOLLAR="pa$$w0rd"
